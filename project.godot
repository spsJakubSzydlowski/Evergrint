; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Evergrint"
config/version="0.3.1"
run/main_scene="uid://bnf23e41dprfh"
config/use_custom_user_dir=true
config/custom_user_dir_name="Evergrint"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

DataManager="*res://scripts/autoloads/DataManager.gd"
Inventory="*res://scripts/autoloads/Inventory.gd"
Signals="*res://scripts/autoloads/Signals.gd"
Global="*res://scripts/autoloads/Global.gd"
InventoryCanvas="*res://scenes/UI/user_interface.tscn"
MiningManager="*res://scripts/autoloads/MiningManager.gd"
AbilityManager="*res://scripts/autoloads/AbilityManager.gd"
AudioManager="*uid://c5rfdyo6mroat"
Tooltip="*uid://cl6ih68eeb4ox"
SceneChanger="*uid://cq24jxsp1mlrs"
SpriteFramesRegistry="*uid://dioel3tfbe4ax"
SaveManager="*uid://bvcwm1g6dsb5p"
SettingsManager="*uid://b2v58gqhxxutb"
Equipment="*uid://dpf1rjtqtavfi"
Enums="*uid://ckdqhn6bbfgf2"
TimeManager="*uid://wgwvxir8hjia"
Controls="*uid://cxketjkigcvp7"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[global_group]

tilemap=""
objectmap=""
ui=""
Player=""
PlayerHitbox=""
Entity=""
menu_buttons=""

[gui]

timers/tooltip_delay_sec=0.02

